# Auto-Commit Daemon Configuration
# Copy this file to .env and adjust values for your setup.

# Path to the Git repository to monitor
REPO_PATH="C:\Users\YourName\Documents\my-project"

# Branch to commit and push to
BRANCH="main"

# Interval between commit cycles (in minutes)
INTERVAL_MINUTES="5"

# Path to log file (relative to script location)
LOG_PATH=".logs\auto-commit.log"

# Enable automatic push after commit (true/false)
PUSH_ENABLED="true"

# Maximum log file size before rotation (in KB)
MAX_LOG_SIZE_KB="1024"

# Maximum individual file size to stage (in MB) — files larger than this are skipped
MAX_FILE_SIZE_MB="50"

# URL to check for network connectivity before pushing
NETWORK_CHECK_URL="https://github.com"
